  "book_title_heading_prefix": "# 希尔伯特",
  "skip_exact_lines": ["*Constance Reid 著；袁向东 李文林 译*"],

  "chapter_pattern": "^第([一二三四五六七八九十廿卅百0-9]+)章[\\s·•埼邨昇]*(.*)$",
  "chapter_count": 25,
  "chapter_titles": {
    "1": "青年时代",
    "2": "良师·益友",
    "3": "哲学博士",
    "4": "巴黎",
    "5": "果尔丹问题",
    "6": "转变",
    "7": "只谈数域",
    "8": "桌子、椅子、啤酒杯",
    "9": "问题",
    "10": "数学的未来",
    "11": "新世纪",
    "12": "第二个青春",
    "13": "热情洋溢的科学生活",
    "14": "空间、时间和数",
    "15": "朋友和学生",
    "16": "物理学",
    "17": "战争",
    "18": "数学基础",
    "19": "新秩序",
    "20": "无限",
    "21": "借来的时间",
    "22": "逻辑和认识自然",
    "23": "云散",
    "24": "晚年",
    "25": "终音"
  },

  "running_headers": ["希尔伯特", "数学世界的亚历山大"],

  "image_plate_range": [2, 32],
  "image_plate_text_threshold": 50,

  "trailer_markers": ["Document generated by Anna"],

  "heading_promotions": [
    {
      "pattern": "(\\n\\s*)后记\\s*(?=“大卫·希尔伯特是他那个时代真正伟大)",
      "title": "后记",
      "replacement": "\\1## 后记\n\n"
    },
    {
      "pattern": "(\\n\\s*)(?=《希尔伯特》中文版由上海科学技术出版社)",
      "title": "译者后记",
      "replacement": "\\1## 译者后记\n\n"
    },
    {
      "pattern": "(内容简介)[:：]\\s*",
      "title": "内容简介"
    },
    {
      "pattern": "^(作者简介)[:：]\\s*",
      "title": "作者简介",
      "flags": ["MULTILINE"]
    },
    {
      "pattern": "^出版说明(?=自中西文明)",
      "title": "出版说明",
      "flags": ["MULTILINE"]
    },
    {
      "pattern": "重读《希尔伯特》之遐想(?=到1965年)",
      "title": "重读《希尔伯特》之遐想"
    }
  ],

  "drop_patterns": [
    "^目录重读《希尔伯特》之遐想\\s*$",
    "^日?第十章数学的未来.*?译后记\\d+\\s*$"
  ],

  "toc_depth": 2,
  "split_level": 2
}
